# Copie este arquivo para ".env" e ajuste os valores reais antes de rodar o bot.
# Nunca faça commit do arquivo ".env" de verdade (ele já está no .gitignore).
# Os valores abaixo são um EXEMPLO preenchido, para você ver o formato esperado
# de cada variável — substitua TELEGRAM_BOT_TOKEN e ADMIN_CHAT_ID pelos seus.

# Token do bot no Telegram, obtido com o @BotFather (formato: números:letras).
TELEGRAM_BOT_TOKEN=
# Seu chat_id no Telegram (o do administrador). Descubra falando com o
# @userinfobot no Telegram.
ADMIN_CHAT_ID=

# Usuário do Telegram do administrador (sem o @), mostrado nas mensagens do
# bot para o usuário saber a quem pedir a senha de acesso.
ADMIN_USERNAME=

# Chave usada para cifrar os e-mails/senhas da Quotex guardados em
# users_data.json. O valor abaixo é apenas um EXEMPLO já no formato certo —
# gere o seu próprio com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Opcionais (valores padrão já mostrados abaixo):
SENHA_LENGTH=10
SENHA_VALIDADE_DIAS=30
RESET_DIARIO_HORA=23
RESET_DIARIO_MINUTO=59

# Usados apenas pelo script de exemplo trade_bot.py (não pelo bot do Telegram):
# QUOTEX_EMAIL=
# QUOTEX_PASSWORD=
